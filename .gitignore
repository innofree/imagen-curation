# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Auto-downloaded models (YuNet etc. are fetched at runtime)
models/

# Runtime outputs (reports, thumbnails, per-run DBs, logs)
runs/

# ---- Next.js UI (app/ui) ----
**/node_modules/
**/.next/
**/out/
**/next-env.d.ts
**/.turbo/

# Runtime SQLite DB (created by `prisma db push`, not source)
*.db
*.db-shm
*.db-wal

# Local path overrides (commit paths.yaml.example instead)
paths.yaml
paths.yml

# ---- misc ----
*.log
.env
.env.*
!.env.example
.DS_Store
Thumbs.db
