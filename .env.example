# docker compose env for fragmented host layouts. Copy to `.env` and edit,
# then: `docker compose up --build`  (compose auto-loads this file).
#
# Only two paths are essential — they can live anywhere on the host:
#   DATASETS_DIR : the SAME datasets folder ai-toolkit trains from (mounted RW;
#                  curation moves rejects to <name>_rejected/ and recaptions).
#   HF_HOME      : a writable HF cache dir (its hub/ holds the VL model). Point
#                  it at an existing cache to avoid re-downloading the model.
#
# Example — comfy-models (infra-poc) fragmented layout:
#   DATASETS_DIR=/home/interbus/workspace/ai-toolkit/datasets
#   HF_HOME=/home/interbus/.cache/huggingface
#
# Example — imagen-lab (co-located layout):
#   DATASETS_DIR=/data/workspace/imagen-lab/datasets
#   HF_HOME=/data/workspace/imagen-lab/downloads/hf

DATASETS_DIR=/home/interbus/workspace/ai-toolkit/datasets
HF_HOME=/home/interbus/.cache/huggingface

# Optional — override the torch wheel channel only if stable cu128 lacks kernels
# for a very new GPU (rare). Stable cu128 torch 2.11 already covers Blackwell /
# sm_120 (verified on RTX PRO 6000), so leave this unset there. Do NOT point it
# at nightly casually — nightly torch/torchvision often fail to co-resolve.
#TORCH_INDEX_URL=https://download.pytorch.org/whl/nightly/cu128

# Optional — host port for the UI (default 8680). Change it to coexist with a
# native/standalone curation UI or anything else already bound to 8680.
#CURATION_PORT=8681

# Optional — default VL evaluator model (New Curation default + worker fallback;
# overridable per-job in the UI).
#DEFAULT_MODEL=huihui-ai/Huihui-Qwen3-VL-8B-Instruct-abliterated

# Optional — HuggingFace token for gated / rate-limited model pulls. Injected
# into the pipeline worker as HF_TOKEN (never shown raw in the UI).
#HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# Optional — extra dataset roots scanned in New Curation besides DATASETS_DIR.
# Comma- or newline-separated absolute host paths (bind-mount them too if Docker).
#EXTRA_DATASET_DIRS=/mnt/nas/datasets,/data/scratch/sets
